{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "QA Buddy",
  "version": "0.7.0",
  "identifier": "com.qabuddy.desktop",
  "build": {
    "frontendDist": "../dist/renderer",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev:renderer",
    "beforeBuildCommand": "npm run build:renderer"
  },
  "app": {
    "windows": [
      {
        "title": "QA Buddy",
        "width": 1560,
        "height": 980,
        "minWidth": 1280,
        "minHeight": 820,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
