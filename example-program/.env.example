# ─────────────────────────────────────────────────────────────────
# Jira & Confluence MCP Server — Environment Variables
# ─────────────────────────────────────────────────────────────────
# Salin file ini menjadi .env lalu isi nilainya

# URL Jira self-hosted (tanpa trailing slash)
# Contoh: https://jira.perusahaan.com
JIRA_BASE_URL=https://jira.perusahaan.com

# Personal Access Token Jira
# Cara generate: Jira → Profile → Personal Access Tokens → Create Token
JIRA_PAT=your_jira_personal_access_token_here

# URL Confluence self-hosted (tanpa trailing slash)
# Contoh: https://confluence.perusahaan.com
CONFLUENCE_BASE_URL=https://confluence.perusahaan.com

# Personal Access Token Confluence
# Cara generate: Confluence → Profile → Personal Access Tokens → Create Token
CONFLUENCE_PAT=your_confluence_personal_access_token_here
